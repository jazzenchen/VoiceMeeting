{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoiceMeeting",
  "version": "0.0.1",
  "identifier": "com.jazzen.voicemeeting",
  "build": {
    "beforeDevCommand": "cd ../frontend && VITE_API_BASE=http://127.0.0.1:8788 bun run dev --host 127.0.0.1 --port 5199",
    "beforeBuildCommand": "cd ../frontend && VITE_API_BASE=http://127.0.0.1:8788 bun run build",
    "frontendDist": "../../frontend/dist",
    "devUrl": "http://127.0.0.1:5199"
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns"
    ],
    "resources": ["resources/voice-meeting-server"],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "infoPlist": "Info.plist",
      "entitlements": "entitlements.plist"
    }
  },
  "app": {
    "security": {
      "csp": null,
      "capabilities": ["default"]
    },
    "windows": [
      {
        "label": "main",
        "title": "VoiceMeeting",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "devtools": true
      }
    ]
  },
  "plugins": {
    "shell": {
      "open": ".*"
    }
  }
}
